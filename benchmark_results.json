      "body": {
        "questions": [
          {
            "question": "According to Newton's First Law of Motion, an object at rest will remain at rest, and an object in motion will remain in motion with constant velocity, unless acted upon by:",
            "options": [
              "A) gravity",
              "B) friction",
              "C) an unbalanced force",
              "D) inertia"
            ],
            "answer": "C) an unbalanced force",
            "explanation": "Newton's First Law states that an object's state of motion (rest or constant velocity) only changes when a net or unbalanced force acts upon it."
          },
          {
            "question": "Newton's Second Law of Motion is mathematically represented by which equation, where F is force, m is mass, and a is acceleration?",
            "options": [
              "A) F = m/a",
              "B) F = m + a",
              "C) F = ma",
              "D) F = m * a²"
            ],
            "answer": "C) F = ma",
            "explanation": "The Second Law states that the acceleration of an object is directly proportional to the net force acting on it and inversely proportional to its mass, giving the formula F = ma."
          },
          {
            "question": "Newton's Third Law of Motion describes the relationship between forces acting on two interacting objects. This law states that for every action force, there is an equal and opposite:",
            "options": [
              "A) acceleration",
              "B) force",
              "C) mass",
              "D) displacement"
            ],
            "answer": "B) force",
            "explanation": "The Third Law states that forces always occur in pairs (action-reaction pairs). These forces are equal in magnitude and opposite in direction."
          }
        ]
      },
